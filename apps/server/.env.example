# Jarwiz server environment.
# Copy to .env (same directory) — the server loads it at startup.

# Optional. When set, link previews get a one-shot claude-haiku-4-5 cleanup
# pass (tidier titles/descriptions). Everything degrades gracefully without
# it — the raw page metadata is used instead. This key never leaves the
# server; the browser only ever sees the parsed LinkPreview JSON.
ANTHROPIC_API_KEY=

# Port for the HTTP server. The web app's Vite dev proxy expects 3001.
PORT=3001
